# 字段级准确率评估的 ground truth（"黄金集"）
#
# 用法：
#   1. 复制为 eval/golden.yaml
#   2. 打开每份 PDF，按模板填入真实值（字段值全部按字符串处理，忽略大小写/千分位/全角）
#   3. 运行 `python -m eval.run_eval` → 输出准确率（MD 里命中字段数 / 总字段数）
#
# 字段选择原则（和 README 里的"抽查 37 个财务数字"方法一致）：
#   - 每份 PDF 15~25 个关键字段
#   - 优先挑："金额、日期、百分比、实体名" 这种有就是对、没就是错的硬事实
#   - 避免长段落描述（写法差异大，会误判为错）
#
# 匹配规则（和召回率归一化一致）：
#   - 归一化后做 substring 查找：MD 里只要包含这个字符串就算命中
#   - 千分位逗号去掉（"897,000,000" 和 "897000000" 相等）
#   - 全角/半角合并（"２０２４" = "2024"）
#   - 大小写忽略

items:
  - name: "天津真格"
    # 请打开这份 PDF，把下面每个字段填成 PDF 里真实出现的值。
    # 示例字段名是建议，可以加减。每个字段一个字符串。
    fields:
      # === 基本信息 ===
      基金全称: "<填：PDF 首页能看到的基金全名>"
      报告期末日期: "<填：例 2024年12月31日>"
      基金规模: "<填：例 897000000，不带千分位>"
      LP名称: "<填：本份报告对应的 LP>"

      # === 财务摘要（小计/合计行）===
      总投资成本合计: "<填：例 849519738>"
      已处置成本合计: "<填>"
      账面成本合计: "<填>"
      已实现价值合计: "<填>"
      未实现价值合计: "<填>"
      总估值倍数: "<填：例 1.5x 或 1.5>"

      # === 任选 3-5 家被投公司的关键数字 ===
      被投1_名称: "<填：例 北京阿吉比科技有限公司>"
      被投1_投资成本: "<填：例 6000000>"
      被投1_投资日期: "<填：例 2016年10月>"
      被投2_名称: "<填>"
      被投2_投资成本: "<填>"

  - name: "昆山峰瑞"
    fields:
      基金全称: "<填>"
      报告期末日期: "<填>"
      基金规模: "<填>"
      # 投资组合里的关键公司、金额、倍数
      被投1_名称: "<填：例 成都博瑞微电子科技有限公司>"
      被投1_投资成本: "<填>"
      被投1_投资日期: "<填>"
      被投1_回报倍数: "<填：例 5.57x>"
      # ...

  - name: "广州越秀"
    fields:
      基金全称: "<填>"
      报告期末日期: "<填>"
      # ...

  - name: "苏州济峰"
    fields:
      基金全称: "<填：例 苏州济峰股权投资合伙企业(有限合伙)>"
      基金编号: "<填：例 SW2127>"
      基金成立日期: "<填：例 2017-5-18>"
      认缴金额: "<填：例 75750>"
      关键人士: "<填>"
      投资者数量: "<填>"
      被投1_名称: "<填：例 河南翔宇医疗设备股份有限公司>"
      被投1_投资额: "<填>"
      被投1_退出方式: "<填>"
      # ...

  - name: "IDG"
    fields:
      # 英文报告
      fund_name: "<填：例 IDG China Capital Fund III LP>"
      as_of_date: "<填：例 December 31, 2024>"
      total_commitments: "<填>"
      total_nav: "<填>"
      # 英文字段值同样按字符串匹配，注意大小写会被忽略
      # ...
